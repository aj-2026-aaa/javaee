<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minishop.order.mapper.ShopOrderMapper">

    <!-- 一对多关联查询：订单及明细（用于详情） -->
    <resultMap id="OrderVOResultMap" type="com.minishop.order.vo.OrderVO">
        <id column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="status" property="status"/>
        <result column="pay_type" property="payType"/>
        <result column="address" property="address"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="pay_time" property="payTime"/>
        <collection property="items" ofType="com.minishop.order.domain.OrderItem">
            <id column="item_id" property="itemId"/>
            <result column="product_id" property="productId"/>
            <result column="product_name" property="productName"/>
            <result column="product_image" property="productImage"/>
            <result column="item_price" property="price"/>
            <result column="quantity" property="quantity"/>
            <result column="item_total_amount" property="totalAmount"/>
        </collection>
    </resultMap>

    <!-- 列表查询结果映射（不含明细，避免重复行） -->
    <resultMap id="OrderListResultMap" type="com.minishop.order.vo.OrderVO">
        <id column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="status" property="status"/>
        <result column="pay_type" property="payType"/>
        <result column="address" property="address"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="pay_time" property="payTime"/>
    </resultMap>

    <sql id="Order_Column_List">
        o.order_id, o.order_no, o.user_id, su.username, o.total_amount, o.status, o.pay_type,
        o.address, o.remark, o.create_time, o.pay_time
    </sql>

    <select id="selectById" resultMap="OrderVOResultMap">
        SELECT
            <include refid="Order_Column_List"/>,
            oi.item_id, oi.product_id, oi.product_name, oi.product_image,
            oi.price AS item_price, oi.quantity, oi.total_amount AS item_total_amount
        FROM shop_order o
        LEFT JOIN sys_user su ON o.user_id = su.user_id
        LEFT JOIN order_item oi ON o.order_id = oi.order_id
        WHERE o.order_id = #{orderId}
        ORDER BY oi.item_id
    </select>

    <select id="selectList" resultMap="OrderListResultMap">
        SELECT <include refid="Order_Column_List"/>
        FROM shop_order o
        LEFT JOIN sys_user su ON o.user_id = su.user_id
        <where>
            <if test="order.orderNo != null and order.orderNo != ''">
                AND o.order_no LIKE CONCAT('%', #{order.orderNo}, '%')
            </if>
            <if test="order.userId != null">
                AND o.user_id = #{order.userId}
            </if>
            <if test="order.status != null">
                AND o.status = #{order.status}
            </if>
            <if test="order.payType != null">
                AND o.pay_type = #{order.payType}
            </if>
        </where>
        ORDER BY o.create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="orderId">
        INSERT INTO shop_order (
            order_no, user_id, total_amount, status, pay_type, address, remark, create_time
        ) VALUES (
            #{orderNo}, #{userId}, #{totalAmount}, #{status}, #{payType}, #{address}, #{remark}, #{createTime}
        )
    </insert>

    <update id="update">
        UPDATE shop_order
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="payType != null">pay_type = #{payType},</if>
            <if test="address != null">address = #{address},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="payTime != null">pay_time = #{payTime}</if>
        </set>
        WHERE order_id = #{orderId}
    </update>

    <delete id="deleteById">
        DELETE FROM shop_order WHERE order_id = #{orderId}
    </delete>

    <select id="countAll" resultType="java.lang.Long">
        SELECT COUNT(*) FROM shop_order
    </select>
</mapper>
